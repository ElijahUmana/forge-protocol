{
  "name": "Forge Protocol",
  "version": "1.0.0",
  "description": "Autonomous multi-agent system that discovers, analyzes, and fixes code quality and security issues in GitHub repositories. Agents operate with ERC-8004 on-chain identities, reputation tracking, and trust-gated collaboration.",
  "operator": {
    "wallet": "0xad114d421E106a845b196BdBe527A9dc4b7e8EF5",
    "name": "Elijah Umana",
    "contact": "elijah@uni.minerva.edu"
  },
  "erc8004": {
    "chain": "ethereum-sepolia",
    "chainId": 11155111,
    "identityRegistry": "0x8004A818BFB912233c491871b3d84c89A494BD9e",
    "reputationRegistry": "0x8004B663056A597Dffe9eCcC1965A193B7388713",
    "agentId": 2221,
    "registrationTx": "0xadf3b56f10b60f40ca7a7973749c9612fd9ed5b0d160a45223e7ae5eb5c9a2ab",
    "reputationTx": "0x96b4ae35ec3d52657f3be1bf135cac24da1b344055eac7196c697daf4ec99929",
    "synthesisAgentId": 35843,
    "synthesisRegistrationTx": "0xc53f8a24b9d206c9134d986b7e4b5452a1d41e3e5a3e2f772d57b3c0d83cd977"
  },
  "agents": [
    {
      "name": "Orchestrator",
      "role": "Task decomposition, delegation, and coordination",
      "capabilities": ["task_planning", "agent_delegation", "progress_tracking"],
      "model": "claude-sonnet-4-20250514"
    },
    {
      "name": "Scanner",
      "role": "Repository discovery and issue identification",
      "capabilities": ["github_api", "code_search", "issue_detection"],
      "model": "claude-sonnet-4-20250514"
    },
    {
      "name": "Analyzer",
      "role": "Deep code analysis and vulnerability detection",
      "capabilities": ["static_analysis", "security_audit", "code_review"],
      "model": "claude-sonnet-4-20250514"
    },
    {
      "name": "Fixer",
      "role": "Code generation and fix implementation",
      "capabilities": ["code_generation", "refactoring", "testing"],
      "model": "claude-sonnet-4-20250514"
    },
    {
      "name": "Reviewer",
      "role": "Fix verification and quality assurance",
      "capabilities": ["code_review", "regression_check", "approval"],
      "model": "claude-sonnet-4-20250514"
    }
  ],
  "tools": [
    "github_api",
    "blockchain_scanner",
    "claude_api",
    "code_analysis",
    "erc8004_registry"
  ],
  "techStack": [
    "typescript",
    "next.js",
    "viem",
    "anthropic-sdk",
    "base-sepolia"
  ],
  "computeConstraints": {
    "maxTokensPerRun": 500000,
    "maxApiCallsPerRun": 100,
    "maxDurationMinutes": 30,
    "costLimitUSD": 5.0
  },
  "taskCategories": [
    "code_security_audit",
    "code_quality_review",
    "bug_detection",
    "automated_fixes",
    "pr_creation"
  ],
  "guardrails": {
    "requireReviewBeforePush": true,
    "blockDestructiveOperations": true,
    "validateTransactionParams": true,
    "maxFileChangesPerPR": 10,
    "requireHumanApprovalForMainBranch": true
  }
}
